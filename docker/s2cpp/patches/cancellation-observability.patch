diff --git src/s2_server.cpp src/s2_server.cpp
index 08fea2d..c2255a7 100644
--- src/s2_server.cpp
+++ src/s2_server.cpp
@@ -297,6 +297,47 @@ struct StreamContext {
     bool error = false;
     std::string error_message;
     std::atomic<bool> cancelled{false};
+    std::atomic<bool> cancel_recorded{false};
+    std::string cancel_reason;
+    std::string cancel_detection_point;
+    std::chrono::steady_clock::time_point cancel_time{};
+    std::chrono::steady_clock::time_point generation_cancel_time{};
+    std::chrono::steady_clock::time_point request_start{};
+    std::atomic<int32_t> generated_frames{0};
+    std::atomic<int32_t> last_frame_index{-1};
+    std::atomic<int32_t> decoded_frames{0};
+    std::atomic<size_t> pcm_bytes_produced{0};
+
+    bool mark_cancelled(const std::string& reason, const std::string& detection_point) {
+        const auto now = std::chrono::steady_clock::now();
+        bool expected = false;
+        if (cancel_recorded.compare_exchange_strong(expected, true)) {
+            {
+                std::lock_guard<std::mutex> lock(mtx);
+                cancel_reason = reason;
+                cancel_detection_point = detection_point;
+                cancel_time = now;
+            }
+            cancelled.store(true);
+            cv.notify_all();
+            S2_LOG_INFO_STREAM("[CANCEL] backend_cancel_detected"
+                << " reason=" << reason
+                << " point=" << detection_point
+                << std::endl);
+            return true;
+        }
+        cancelled.store(true);
+        cv.notify_all();
+        return false;
+    }
+
+    long long detection_elapsed_ms(std::chrono::steady_clock::time_point when) const {
+        if (!cancel_recorded.load()) {
+            return -1;
+        }
+        return std::chrono::duration_cast<std::chrono::milliseconds>(
+            when - cancel_time).count();
+    }
 };

