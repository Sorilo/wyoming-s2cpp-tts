# =============================================================================
# .env.example — wyoming-s2cpp-tts v0.1.0
# =============================================================================
# Copy to .env and adjust for your deployment.
# .env is gitignored — do not commit real values.

# ---------------------------------------------------------------------------
# Image tags (pin to a verified sha-* for production)
# ---------------------------------------------------------------------------
BACKEND_IMAGE=ghcr.io/sorilo/wyoming-s2cpp-tts-backend:0.1.0
WRAPPER_IMAGE=ghcr.io/sorilo/wyoming-s2cpp-tts:0.1.0

# ---------------------------------------------------------------------------
# Host paths (adjust for your Unraid/Docker host)
# ---------------------------------------------------------------------------
# Directory containing GGUF model + tokenizer.json (mounted read-only).
MODELS_DIR=/mnt/user/appdata/s2cpp/models
# Directory containing .s2voice profile files.
VOICES_DIR=/mnt/user/appdata/s2cpp/voices

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------
# Docker network name for internal wrapper<->backend communication.
NETWORK_NAME=s2cpp-net

# ---------------------------------------------------------------------------
# Wrapper settings
# ---------------------------------------------------------------------------
# Host port for Home Assistant Wyoming Protocol (TCP).
WYOMING_HOST_PORT=10200
# Streaming synthesis (true recommended for HA streaming TTS).
S2_STREAM=true
# Optional default voice profile ID (leave empty for s2-pro fallback).
S2_DEFAULT_VOICE=
# Log level: debug | info | warning | error
LOG_LEVEL=info
# Graceful shutdown grace period (seconds).
SHUTDOWN_GRACE_TIMEOUT_SEC=30
# Optional admin HTTP server (loopback-only, disabled by default).
ADMIN_HTTP_ENABLED=false

# ---------------------------------------------------------------------------
# Backend settings
# ---------------------------------------------------------------------------
# Path to GGUF model inside the container (relative to /models mount).
S2_MODEL=/models/s2-pro-q4_k_m.gguf
# GPU layers to offload (-1 = auto/all, 0 = CPU only).
S2_GPU_LAYERS=-1
# CPU threads (0 = auto).
S2_THREADS=8
# Keep codec on CPU (false = GPU codec).
S2_CODEC_CPU=false
# CUDA device index.
S2_CUDA_DEVICE=0
# Backend log level.
S2_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Streaming / performance tuning (Phase 8C/8E)
# ---------------------------------------------------------------------------
# Codec context frames (validated: 32 for RTX 3080 Q4_K_M).
S2_CODEC_DECODE_CONTEXT_FRAMES=32
# Streaming decode stride frames (validated: 32 for RTX 3080 Q4_K_M).
S2_STREAM_DECODE_STRIDE_FRAMES=32
# Frame holdback before first emission (0 for no holdback).
S2_STREAM_HOLDBACK_FRAMES=0
# Backend low-latency mode (true = stride-aware streaming).
S2_LOW_LATENCY=true
