# ---------------------------------------------------------------------------
# Example configuration for the Unraid host voice-import operator.
#
# Copy this file to config.env and adjust values for your deployment.
# Only the keys listed below are recognized.  Unknown keys cause parse errors.
#
# This file must NOT contain transcript content or secrets.
# ---------------------------------------------------------------------------

# Backend Docker container name (must match exactly, no wildcards)
BACKEND_CONTAINER=s2cpp-backend

# Immutable backend image reference (REQUIRED: set your actual image reference)
# Must be sha256:<64-char-digest> or registry/repo:sha-<40-char-hex-git-revision>
BACKEND_IMAGE=REQUIRED_SET_IMMUTABLE_IMAGE_REFERENCE

# Host directory paths
MODELS_DIR=/mnt/user/appdata/s2cpp/models
VOICES_DIR=/mnt/user/appdata/s2cpp/voices
IMPORT_INPUTS_DIR=/mnt/user/appdata/s2cpp/voice-import-inputs

# Container-side paths for model and tokenizer
MODEL_CONTAINER_PATH=/models/s2-pro-q6_k.gguf
TOKENIZER_CONTAINER_PATH=/models/tokenizer.json

# GPU configuration
CUDA_DEVICE=0
GPU_LAYERS=99

# Timeouts (seconds)
STOP_TIMEOUT_SEC=30
IMPORT_TIMEOUT_SEC=600
RESTART_TIMEOUT_SEC=120

# Health check polling
HEALTH_POLL_INTERVAL_SEC=2
HEALTH_POLL_TIMEOUT_SEC=120

# Expected revisions (REQUIRED: set your actual revisions)
# Source repository revision (40-char lowercase hex)
EXPECTED_SOURCE_REVISION=REQUIRED_SET_40_HEX_SOURCE_REVISION_HERE
# s2.cpp build revision (pinned to validated commit)
EXPECTED_S2CPP_REVISION=2c33261938da1a41d713768b1b391b4d368d7d2c

# Lock file path (prevents concurrent imports)
LOCK_FILE=/mnt/user/appdata/s2cpp/operator/import.lock
